{
  "name": "zerotier-toolkit",
  "description": "A cross-platform ZeroTier desktop client",
  "version": "1.1.0",
  "license": "MIT",
  "repository": "https://github.com/Cowjiang/zerotier-toolkit",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "build:no-bundle": "tauri build --no-bundle",
    "build:dev-updater": "tauri dev --config src-tauri/tauri.debug.conf.json",
    "info": "tauri info",
    "tauri": "tauri",
    "test": "vitest",
    "test:no-watch": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --fix --ext js,jsx,ts,tsx",
    "vite:dev": "vite",
    "vite:build": "tsc && vite build",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@heroui/react": "2.8.10",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "~2.3.2",
    "@tauri-apps/plugin-fs": "~2.5.0",
    "@tauri-apps/plugin-http": "~2.5.8",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "classnames": "^2.5.1",
    "framer-motion": "^12.38.0",
    "i18next": "^25.10.10",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.7.4",
    "react-router-dom": "^7.14.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/react": "^14.3.1",
    "@types/node": "^24.12.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.3",
    "prettier": "3.3.3",
    "tailwindcss": "^4.2.2",
    "typescript": "5.5.4",
    "unplugin-preprocessor-directives": "^1.2.0",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  }
}
